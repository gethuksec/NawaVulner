# Image dev API — devDependencies + `npm run dev` (tsx watch). Dipakai oleh docker-compose.override.example.yml
FROM node:20-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi
COPY tsconfig.json ./
COPY src ./src
EXPOSE 3001
CMD ["npm", "run", "dev"]

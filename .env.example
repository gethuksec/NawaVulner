# Salin ke .env dan sesuaikan. Jangan commit .env.

# PostgreSQL (service nawa-db — override jika perlu)
POSTGRES_USER=nawa
POSTGRES_PASSWORD=nawa_dev_change_me
POSTGRES_DB=nawavulner

# API — URL koneksi ke DB dari dalam jaringan Docker
DATABASE_URL=postgresql://nawa:nawa_dev_change_me@nawa-db:5432/nawavulner

# Session & flag (wajib kuat di produksi)
SESSION_SECRET=change_me_min_32_chars_random_session
PEPPER_FLAG=change_me_pepper_for_flag_hash

# Mode unlock challenge: free | strict
CHALLENGE_UNLOCK_MODE=free

# Port host untuk reverse proxy (browser membuka ini)
PUBLIC_PORT=8080

# URL publik yang dipakai browser (untuk respons API lab-url). Sesuaikan jika PUBLIC_PORT bukan 8080.
PUBLIC_BASE_URL=http://localhost:8080

# Slug lab yang di-deploy (bundle Fase 1). Default sama dengan docker-compose.yml (18 slug).
LAB_DEPLOYED_SLUGS=a01-idor-profil-user,a01-force-browse-admin,a01-jwt-privilege-escalation,a01-ssrf-internal-discovery,a01-csrf-cors-chain,a01-mass-assignment-hpe,a02-default-or-hardcoded-credentials,a02-directory-listing,a02-verbose-errors,a02-missing-security-headers,a02-cloud-metadata-ssrf,a02-debug-endpoint-leak,a05-sqli-login-bypass,a05-reflected-xss,a05-sqli-union,a05-stored-xss-cookie-steal,a05-sqli-blind-time,a05-ssti-rce

# Bonus poin first blood per challenge (ditambahkan ke respons flag saat benar)
FIRST_BLOOD_BONUS_POINTS=50

# Rate limit (opsional)
RATE_LIMIT_AUTH_MAX=40
RATE_LIMIT_LAB_MAX=60

# Bind API (di dalam container gunakan default 0.0.0.0)
LISTEN_HOST=0.0.0.0

# Image Node untuk build API, dashboard, dan lab bundle (override jika pull Docker Hub timeout)
# Contoh: NODE_IMAGE=node:20-bookworm-slim
